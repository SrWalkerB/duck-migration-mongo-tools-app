# Chave usada para criptografar as connection strings no SQLite.
# Se não definir, será usada a chave padrão de desenvolvimento.
# Em produção, defina uma frase forte e única (ex.: gerada com openssl rand -base64 32).
# Atenção: ao trocar a frase, conexões já salvas não poderão ser descriptografadas.
DUCK_ENCRYPTION_PASSPHRASE=

# Opcional: pasta onde fica o arquivo do SQLite (default: sidecar/data)
# DUCK_DATA_DIR=

# Opcional: porta do sidecar (default: 45678)
# SIDECAR_PORT=
